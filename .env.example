# Copy to .env and fill in. Never commit .env.

# Alpaca Markets — free tier gives historical SIP 1-min bars (>15 min delay)
# Get keys at: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# FRED — Federal Reserve Economic Data, free key
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# DATA_ROOT — absolute path to the warehouse root containing ASSET/ and MACRO/.
# Leave unset to default to the repo root (everything co-located with code).
# Point at an external SSD in production, e.g.:
#   DATA_ROOT=/Volumes/Extreme SSD/project-x-data
DATA_ROOT=
